# Copy this file to .env and fill in real values. Never commit the real .env file.

ENV=production
DEBUG=false

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME

# Shared secret the WordPress snippet sends as the X-API-Key header
API_KEY=CHANGE_ME

DATABASE_URL=postgresql://moajam:moajam@db:5432/moajam

# Get this from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6

CORS_ORIGINS=["https://moajamalmaani.com","https://www.moajamalmaani.com"]

# Render stays stateless: every source/output file is stored in this WordPress
# site's Media Library, not on Render's own disk.
WP_BASE_URL=https://moajamalmaani.com

# WordPress Application Password for source-file uploads via /wp-json/wp/v2/media
# (WordPress admin -> Users -> Profile -> Application Passwords). Keep the real
# value in .env only - never commit it.
WP_USER=CHANGE_ME
WP_APP_PASSWORD=CHANGE_ME

COMPANY_NAME=Moajam Almaani
COMPANY_EMAIL=info@moajamalmaani.com
COMPANY_ADDRESS=
CURRENCY=EGP

# Optional - leave blank to disable online payment links
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
